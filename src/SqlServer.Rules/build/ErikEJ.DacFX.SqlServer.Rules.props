<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <!-- Enable code analysis by default if DSP property is present (indicator of classic .sqlproj) -->
    <!-- Only set if not already configured by the user -->
    <RunSqlCodeAnalysis Condition="'$(DSP)' != '' And '$(RunSqlCodeAnalysis)' == ''">True</RunSqlCodeAnalysis>
  </PropertyGroup>
</Project>
